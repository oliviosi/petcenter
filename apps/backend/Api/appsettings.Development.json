{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "NotificationOptions": {
    "MaxAttempts": 3,
    "BaseDelayMs": 500
  },
  "Email": {
    "FromAddress": "no-reply@petcenter.local"
  },
  "RabbitMq": {
    "Bookings": {
      "HostName": "localhost",
      "Port": 5672,
      "UserName": "guest",
      "Password": "guest",
      "VirtualHost": "/",
      "Exchange": "bookings",
      "ExchangeType": "direct",
      "RequestedRoutingKey": "booking.requested",
      "ConfirmedQueue": "booking.confirmed.api",
      "ConfirmedRoutingKey": "booking.confirmed",
      "RejectedQueue": "booking.rejected.api",
      "RejectedRoutingKey": "booking.rejected"
    }
  }
}
