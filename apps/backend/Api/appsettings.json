{
  "Jwt": {
    "Issuer": "petcenter-api",
    "Audience": "petcenter-client",
    "ExpiryMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "StorefrontDomainVerification": {
    "ExpectedTarget": "storefront.petcenter.local",
    "ApexExpectedTargets": [
      "198.51.100.10",
      "2001:db8::10",
      "apex.storefront.petcenter.local"
    ],
    "WorkerInterval": "00:05:00",
    "RetryDelay": "00:15:00",
    "ActiveMonitoringInterval": "12:00:00",
    "BatchSize": 25
  },
  "StorefrontDomainCertificateReadiness": {
    "ProbePath": "/",
    "SuccessStatusCodes": [ 200, 301, 302, 307, 308 ],
    "RequestTimeout": "00:00:10",
    "RetryDelay": "00:15:00"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
